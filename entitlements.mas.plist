<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Sandbox — mandatory for Mac App Store -->
  <key>com.apple.security.app-sandbox</key>
  <true/>

  <!-- Outgoing network: model downloads from HuggingFace / MLC CDN -->
  <key>com.apple.security.network.client</key>
  <true/>

  <!-- Incoming connections: local OpenAI-compatible HTTP server -->
  <key>com.apple.security.network.server</key>
  <true/>

  <!-- Electron / V8 JIT compilation -->
  <key>com.apple.security.cs.allow-jit</key>
  <true/>

  <!-- Required by Electron renderer process -->
  <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
  <true/>

  <!-- Required for Electron's dynamic library loading -->
  <key>com.apple.security.cs.disable-library-validation</key>
  <true/>
</dict>
</plist>
